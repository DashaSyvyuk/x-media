<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Контроль продуктів</title>

    {{ encore_entry_link_tags('app') }}

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/datatables.net-bs5@1.13.10/css/dataTables.bootstrap5.min.css" rel="stylesheet">

    <style>
        body { background:#f7f7f7; }

        .price-col { background: rgba(255,193,7,0.12); }
        .oldprice-col { background: rgba(220,53,69,0.10); }
        .rozetka-col { background: rgba(13,110,253,0.08); }
        .rozetka-old-col { background: rgba(13,110,253,0.05); }
        .plprice-col { background: rgba(25, 135, 84, 0.10); }

        table.dataTable tbody td { vertical-align: middle; }
        .cell-input { min-width: 120px; }
        .code-cell { line-height: 1.15; }
        .strike { text-decoration: line-through; }

        /* ✅ Premium row highlights (apply to cells) */
        .dirty-row > * { background-color: #fff3cd !important; }
        .saved-row > * { background-color: #d1e7dd !important; }
        .error-row > * { background-color: #f8d7da !important; }

        /* ✅ Cell validation highlights */
        td.cell-bad { background-color: #f8d7da !important; } /* light red */
        td.cell-warn { background-color: #fff3cd !important; } /* light yellow */

        /* Filters */
        .filters-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(180px, 1fr));
            gap: .5rem;
            align-items: end;
        }
        @media (max-width: 900px) {
            .filters-grid { grid-template-columns: 1fr; }
        }
        .filter-field label {
            display: block;
            font-size: .85rem;
            color: #6c757d;
            margin-bottom: .2rem;
        }

        /* Link icons */
        .link-icon, .link-missing {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 34px; height: 34px;
            border-radius: 10px;
            text-decoration: none;
            cursor: pointer;
            user-select: none;
        }
        .link-icon { background: rgba(25, 135, 84, 0.12); color: #198754; }
        .link-icon:hover { background: rgba(25, 135, 84, 0.20); }
        .link-missing { background: rgba(108,117,125,0.10); color: rgba(108,117,125,0.85); }
        .link-missing:hover { background: rgba(108,117,125,0.16); }
        .link-icon svg, .link-missing svg { width: 18px; height: 18px; display:block; }

        .js-save.btn-success,
        .js-save.btn-danger { color: #fff; }
    </style>
</head>

<body>

<div class="container-fluid mt-4">
    <div class="mb-3">
        <h2 class="mb-0">Контроль продуктів</h2>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <div class="fw-semibold mb-2">Фільтри</div>

            <div class="filters-grid mb-2">
                <div class="filter-field">
                    <label for="filterStatus">Статус</label>
                    <select id="filterStatus" class="form-select form-select-sm">
                        <option value="">Всі</option>
                        <option value="Активний">Активний</option>
                        <option value="Заблокований">Заблокований</option>
                    </select>
                </div>

                <div class="filter-field">
                    <label for="filterCategory">Категорія</label>
                    <select id="filterCategory" class="form-select form-select-sm">
                        <option value="">Всі</option>
                        {% for c in categories %}
                            <option value="{{ c.id }}">{{ c.title ?? c.name ?? ('#' ~ c.id) }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div></div>

                <div class="d-flex justify-content-end">
                    <button id="resetFilters" class="btn btn-outline-secondary btn-sm">Скинути</button>
                </div>
            </div>

            <div class="filters-grid">
                <div class="filter-field">
                    <label for="filterId">Id</label>
                    <input id="filterId" class="form-control form-control-sm" placeholder="Напр. 123">
                </div>

                <div class="filter-field">
                    <label for="filterCode">Код</label>
                    <input id="filterCode" class="form-control form-control-sm" placeholder="Пошук по коду">
                </div>

                <div></div>
                <div></div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table id="productsTable" class="table table-striped table-hover table-sm w-100">
                    <thead>
                    <tr>
                        <th>Id</th>
                        <th>Назва</th>
                        <th>Категорія</th>
                        <th>Код 1</th>

                        <th class="price-col">Ціна</th>
                        <th class="oldprice-col"><span class="strike">Ціна</span></th>

                        <th class="rozetka-col">Ціна розетка</th>
                        <th class="rozetka-old-col"><span class="strike">Ціна розетка</span></th>

                        <th class="plprice-col">Ціна в Польщі</th>
                        <th>Посилання</th>
                        <th>Статус</th>
                        <th>Дія</th>
                    </tr>
                    </thead>

                    <tbody>
                    {% set csrf = csrf_token('product_inline_update') %}

                    {% for p in products %}
                        {% set catId = p.category.id ?? p.categoryId ?? p.category_id ?? '' %}

                        {% set code1 = p.productCode ?? p.product_code ?? '' %}
                        {% set code2 = p.productCode2 ?? p.product_code2 ?? '' %}

                        {% set priceVal = p.price ?? null %}
                        {% set oldVal = p.crossedOutPrice ?? p.crossed_out_price ?? null %}

                        {% set rz = p.rozetka ?? null %}
                        {% set rzPrice = rz ? (rz.price ?? null) : null %}
                        {% set rzOld = rz ? (rz.crossedOutPrice ?? rz.crossed_out_price ?? null) : null %}

                        {% set plPrice = p.pricePl ?? p.price_pl ?? null %}
                        {% set url = p.url ?? p.link ?? p.productUrl ?? null %}

                        {% set st = p.status ?? 'Активний' %}
                        {% set isActive = (st == 'Активний') %}

                        {# ✅ Rule 3: crossed_out_price <= price => bad (red) #}
                        {% set isOldBad = (oldVal is not null and priceVal is not null and oldVal <= priceVal) %}
                        {% set isRzOldBad = (rzOld is not null and rzPrice is not null and rzOld <= rzPrice) %}

                        {# ✅ Rule 4: rozetka_price is within +5% of price (or less) => bad (red)
                           condition: rzPrice > price AND rzPrice <= price*1.05
                        #}
                        {% set isRzTooClose = (rzPrice is not null and priceVal is not null and rzPrice > priceVal and rzPrice <= (priceVal * 1.05)) %}

                        <tr data-id="{{ p.id }}" data-csrf="{{ csrf }}" data-status="{{ st }}">
                            <td>{{ p.id }}</td>

                            <td style="font-weight:600">{{ p.title ?? '-' }}</td>

                            <td data-category-id="{{ catId }}">
                                {{ p.category.title ?? p.category.name ?? ('#' ~ (catId ?: '?')) }}
                            </td>

                            <td class="code-cell">
                                {% if code1 %}{{ code1 }}{% else %}-{% endif %}
                                {% if code2 %}<br>{{ code2 }}{% endif %}
                            </td>

                            <td class="price-col" data-order="{{ priceVal ?? 0 }}">
                                <input class="form-control form-control-sm cell-input js-price"
                                       type="number" step="0.01"
                                       value="{{ priceVal ?? '' }}" />
                            </td>

                            <td class="oldprice-col {{ isOldBad ? 'cell-bad' : '' }}" data-order="{{ oldVal ?? 0 }}">
                                <input class="form-control form-control-sm cell-input js-oldprice strike"
                                       type="number" step="0.01"
                                       value="{{ oldVal ?? '' }}"
                                       placeholder="-" />
                            </td>

                            <td class="rozetka-col {{ isRzTooClose ? 'cell-bad' : '' }}" data-order="{{ rzPrice ?? 0 }}">
                                <input class="form-control form-control-sm cell-input js-rz-price"
                                       type="number" step="0.01"
                                       value="{{ rzPrice ?? '' }}"
                                       placeholder="-" />
                            </td>

                            <td class="rozetka-old-col {{ isRzOldBad ? 'cell-bad' : '' }}" data-order="{{ rzOld ?? 0 }}">
                                <input class="form-control form-control-sm cell-input js-rz-old strike"
                                       type="number" step="0.01"
                                       value="{{ rzOld ?? '' }}"
                                       placeholder="-" />
                            </td>

                            <td class="plprice-col" data-order="{{ plPrice ?? 0 }}">
                                {% if plPrice is not null and plPrice != '' %}{{ plPrice }}{% else %}<span class="text-muted">-</span>{% endif %}
                            </td>

                            <td>
                                {% if url %}
                                    <a class="link-icon" href="{{ url }}" target="_blank" rel="noopener noreferrer" title="Відкрити посилання">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                            <path d="M10 13a5 5 0 0 1 0-7l1.5-1.5a5 5 0 0 1 7 7L17 13"></path>
                                            <path d="M14 11a5 5 0 0 1 0 7L12.5 19.5a5 5 0 0 1-7-7L7 11"></path>
                                        </svg>
                                    </a>
                                {% else %}
                                    <span class="link-missing" title="Немає посилання">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                            <path d="M10 13a5 5 0 0 1 0-7l1.5-1.5a5 5 0 0 1 7 7L17 13"></path>
                                            <path d="M14 11a5 5 0 0 1 0 7L12.5 19.5a5 5 0 0 1-7-7L7 11"></path>
                                            <path d="M4 4l16 16"></path>
                                        </svg>
                                    </span>
                                {% endif %}
                            </td>

                            <td>
                                <div class="form-check form-switch m-0">
                                    <input class="form-check-input js-status-switch"
                                           type="checkbox"
                                           role="switch"
                                            {{ isActive ? 'checked' : '' }}>
                                </div>
                            </td>

                            <td>
                                <button class="btn btn-primary btn-sm js-save" disabled>Зберегти</button>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/datatables.net@1.13.10/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/datatables.net-bs5@1.13.10/js/dataTables.bootstrap5.min.js"></script>

<script>
    $(function () {
        const table = $('#productsTable').DataTable({
            pageLength: 50,
            order: [[0, 'desc']],
        });

        function setBtnState($btn, state) {
            $btn.removeClass('btn-primary btn-success btn-danger');
            if (state === 'ok') $btn.addClass('btn-success');
            else if (state === 'err') $btn.addClass('btn-danger');
            else $btn.addClass('btn-primary');
        }

        function clearRowStates($tr){
            $tr.removeClass('dirty-row saved-row error-row');
        }

        function markDirty($tr){
            clearRowStates($tr);
            $tr.addClass('dirty-row');
            const $btn = $tr.find('.js-save');
            $btn.prop('disabled', false);
            setBtnState($btn, 'idle');
        }

        function markSaved($tr){
            clearRowStates($tr);
            $tr.addClass('saved-row');
            setTimeout(() => $tr.removeClass('saved-row'), 900);
        }

        function markError($tr){
            clearRowStates($tr);
            $tr.addClass('error-row');
        }

        function numVal($v){
            if ($v === null || $v === undefined) return null;
            const s = String($v).trim().replace(',', '.');
            if (s === '') return null;
            const n = parseFloat(s);
            return isNaN(n) ? null : n;
        }

        function validateRow($tr){
            // remove old cell highlights
            const $tdOld = $tr.find('td.js-td-oldprice');
            const $tdRzPrice = $tr.find('td.js-td-rz-price');
            const $tdRzOld = $tr.find('td.js-td-rz-old');

            $tdOld.removeClass('cell-bad');
            $tdRzPrice.removeClass('cell-bad');
            $tdRzOld.removeClass('cell-bad');

            const price = numVal($tr.find('.js-price').val());
            const oldP  = numVal($tr.find('.js-oldprice').val());
            const rzP   = numVal($tr.find('.js-rz-price').val());
            const rzOld = numVal($tr.find('.js-rz-old').val());

            // Rule 3: old <= price => bad
            if (price !== null && oldP !== null && oldP <= price) {
                $tdOld.addClass('cell-bad');
            }
            if (rzP !== null && rzOld !== null && rzOld <= rzP) {
                $tdRzOld.addClass('cell-bad');
            }

            // Rule 4: rzPrice > price and within +5% => bad
            if (price !== null && rzP !== null && rzP > price && rzP <= (price * 1.05)) {
                $tdRzPrice.addClass('cell-bad');
            }
        }

        // Filters
        $.fn.dataTable.ext.search.push(function (settings, data, dataIndex) {
            if (settings.nTable.id !== 'productsTable') return true;
            const row = table.row(dataIndex).node();

            const stFilter = $('#filterStatus').val();
            if (stFilter) {
                const stVal = $(row).attr('data-status') || '';
                if (String(stVal) !== String(stFilter)) return false;
            }

            const catFilter = $('#filterCategory').val();
            if (catFilter) {
                const catId = $('td:eq(2)', row).attr('data-category-id') || '';
                if (String(catId) !== String(catFilter)) return false;
            }

            const idFilter = ($('#filterId').val() || '').trim();
            if (idFilter) {
                const idVal = (data[0] || '').trim();
                if (idVal !== idFilter) return false;
            }

            const codeFilter = ($('#filterCode').val() || '').trim().toLowerCase();
            if (codeFilter) {
                const codeText = $('td:eq(3)', row).text().toLowerCase().replace(/\s+/g, ' ').trim();
                if (!codeText.includes(codeFilter)) return false;
            }

            return true;
        });

        $('#filterStatus, #filterCategory').on('change', () => table.draw());
        $('#filterId, #filterCode').on('keyup change', () => table.draw());

        $('#resetFilters').on('click', function () {
            $('#filterStatus').val('');
            $('#filterCategory').val('');
            $('#filterId').val('');
            $('#filterCode').val('');
            table.search('').columns().search('');
            table.draw();
        });

        // mark dirty + keep sorting via data-order + validate
        $('#productsTable').on('input change', '.js-price, .js-oldprice, .js-rz-price, .js-rz-old', function () {
            const $tr = $(this).closest('tr');
            const $td = $(this).closest('td');
            const v = parseFloat(String($(this).val()).replace(',', '.'));
            $td.attr('data-order', isNaN(v) ? 0 : v);

            validateRow($tr);
            markDirty($tr);
        });

        $('#productsTable').on('change', '.js-status-switch', function () {
            const $tr = $(this).closest('tr');
            const active = $(this).is(':checked');
            $tr.attr('data-status', active ? 'Активний' : 'Заблокований');
            markDirty($tr);
            table.draw();
        });

        $('#productsTable').on('click', '.js-save', async function () {
            const $btn = $(this);
            const $tr = $btn.closest('tr');

            const payload = {
                id: $tr.data('id'),
                price: $tr.find('.js-price').val(),
                crossed_out_price: $tr.find('.js-oldprice').val(),
                rozetka_price: $tr.find('.js-rz-price').val(),
                rozetka_crossed_out_price: $tr.find('.js-rz-old').val(),
                status: $tr.attr('data-status') || 'Активний',
                _token: $tr.data('csrf'),
            };

            $btn.prop('disabled', true);

            try {
                const res = await fetch('/admin/control-price/update', {
                    method: 'POST',
                    headers: {'Content-Type':'application/json'},
                    body: JSON.stringify(payload),
                });

                let ok = res.ok;
                try {
                    const json = await res.json();
                    ok = ok && !!json.ok;
                } catch (e) {
                    ok = false;
                }
                if (!ok) throw new Error('save failed');

                setBtnState($btn, 'ok');
                markSaved($tr);
                $btn.prop('disabled', true);

            } catch (e) {
                setBtnState($btn, 'err');
                markError($tr);
                $btn.prop('disabled', false);
            }
        });

        // initial validation pass
        $('#productsTable tbody tr').each(function(){ validateRow($(this)); });

    });
</script>

<script>
    /* add td markers for validation targets (kept separate to avoid messy twig changes) */
    $(function(){
        // Mark specific cells by adding classes based on column index
        // Columns:
        // 0 Id,1 title,2 category,3 code,4 price,5 old,6 rz price,7 rz old,8 pl,9 link,10 status,11 action
        $('#productsTable tbody tr').each(function(){
            const $tr = $(this);
            $tr.children('td').eq(5).addClass('js-td-oldprice');
            $tr.children('td').eq(6).addClass('js-td-rz-price');
            $tr.children('td').eq(7).addClass('js-td-rz-old');
        });
    });
</script>

</body>
</html>
